(** * PROPERTY *)
(** The following definition is to definite the property of three points collinear, and "col1" is the example for it. *)

Definition collin (A B P : Point) :=
  exists (u v t : Z), u + v = t ->
                      Pplus (Pmults u A) (Pmults v B) = Pmults t P.

(** NOT A B P different *)
 
Example col1: collin (0, 0) (2, 2) (1, 1).
Proof.
  unfold collin.
  exists 1. exists 1. exists 2.
  intros; reflexivity.
Qed.

Lemma left_O: forall (A : Point), Pplus O A = A.
Proof.
  intros. unfold O, Pplus.
  induction A. auto.  
Qed.

Axiom right_O: forall A, Pplus A O = A.
Axiom lmult_O: forall A, Pmults A O = O.
Axiom Unit_right: forall A, Pmults 1 A = A.
Axiom Pplus_1: forall A B, Pplus A B = O <-> A = Pmults (-1) B.
Axiom Pmults_1: forall n m A, Pmults (n) (Pmults m A) = Pmults (n * m) A.


Lemma Alge: forall x: Z, (-1) * (-1 *x) = x.
Proof. intros. omega. Qed.

Lemma collinO1: forall A B,
  (exists (l : Z), A = Pmults l B) -> collin A B O. 
Proof.
  intros. unfold collin. destruct H.  
  exists 1. exists (-1 * x). exists (1-x).
  intros. rewrite lmult_O with (A := (1-x)). rewrite Unit_right.
  apply Pplus_1. rewrite Pmults_1. rewrite Alge.
  auto.
Qed.





