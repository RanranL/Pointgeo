From Coq Require Import Arith.Arith.
Require Import ZArith.

Open Scope Z.

(** * The definition of point *)

Inductive Point : Type :=
| pair (n1 n2 : Z) : Point.

Notation " ( x , y ) " := (pair x y).

Check pair 1 2.
Check (1,2).

(** * DEFINITION *)
(** ** point_add *)

Definition Pplus (A B : Point) : Point :=
  match A, B with
  | (a, b), (c, d)
    => (a + c, b + d)
  end.

Compute Pplus (1, 2) (4, 6).

(** ** Pmults *)

Definition Pmults (n : Z) (A : Point) :=
  match A with
  | (x, y) => (n * x, n * y)
  end.


Compute Pmults 2 (1, 2).
(*Notation " x * y " := (Pmults x y).*)

(** * O *)

Definition O (A : Point) : Prop := A = (0, 0).

(** * PROPERTY *)
(** The following definition is to definite the property of three points collinear, and "col1" is the example for it. *)

Definition collin (A B P : Point) :=
  exists (u v t : Z), u + v = t ->
                      Pplus (Pmults u A) (Pmults v B) = Pmults t P.

Example col1: collin (0, 0) (2, 2) (1, 1).
Proof.
  unfold collin.
  exists 1. exists 1. exists 2.
  intros; reflexivity.
Qed.   







