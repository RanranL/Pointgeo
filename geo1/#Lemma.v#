Theorem Pplus_comm: forall A B, A + B = B + A.
Proof. 
  unfold Pplus.
  induction A. induction B.
  rewrite Rplus_comm.
  rewrite Rplus_comm with (r1 := n3) (r2 := n2).
  reflexivity.
Qed.
Locate Pplus_minus.
Lemma Pplus_minus: forall A B, A + (B - A) = B.
Proof.
  intros. unfold Pplus, Pminus. induction A, B.
  do 2 rewrite Rplus_minus; auto.
Qed.

Lemma Pplus_opp_r: forall P, (P + -P) = O.
Proof.
  intros. unfold Pplus, Pneg, O. induction P.
  do 2 rewrite Rplus_opp_r; auto.
Qed.

