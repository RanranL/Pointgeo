Lemma Pplus_eq_reg_l: forall P A B, P + A = P + B -> A = B.
Proof.
  Unfold. induction P, A, B.
  intros. apply Point_eq in H. induction H.
  apply Rplus_eq_reg_l in H; rewrite H.
  apply Rplus_eq_reg_l in H0; rewrite H0.
  auto.
Qed.
  
Lemma Pplus_eq_compat_l: forall P A B, A = B -> P + A = P + B.
Proof. intros. rewrite H. reflexivity. Qed.

Lemma Pplus_eq_compat_r: forall P A B, A = B -> A + P = B + P.
Proof. intros. rewrite H. reflexivity. Qed.

