Lemma omega3: forall x y, (x + 0, y + 0) = (x, y).  
Proof. intros. do 2 rewrite Rplus_0_r.  reflexivity. Qed. 

Lemma Pplus_0_r: forall A, A + O = A.
Proof.
  intros. unfold O. unfold Pplus. induction A. apply omega3.
Qed.

Lemma Pplus_0_r': forall A, A + O == A.
Proof.
