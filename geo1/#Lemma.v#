Lemma Pplus_0_r_uniq: forall P A, P + A = P -> A = O.
Proof.
  Unfold. induction P, A.
  intros. apply Point_eq in H. induction H.
  apply Rplus_0_r_uniq in H; rewrite H.
  apply Rplus_0_r_uniq in H0; rewrite H0. reflexivity.
Qed.
                                                           
Lemma Pplus_0_l: forall (A : Point), O + A = A.
Proof. 
  intros. unfold O, Pplus.
