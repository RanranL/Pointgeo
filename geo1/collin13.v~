(** * PROPERTY *)
(** The following definition is to definite the property of three points collinear, and "col1" is the example for it. *)

Definition collin (A B P : Point) :=
  exists (u v t : Z), u + v = t ->
                      Pplus (Pmults u A) (Pmults v B) = Pmults t P.

(** NOT A B P different *)
 
Example col1: collin (0, 0) (2, 2) (1, 1).
Proof.
  unfold collin.
  exists 1. exists 1. exists 2.
  intros.  reflexivity.
Qed.

Lemma left_O: forall (A : Point), Pplus O A = A.
Proof.
  intros. unfold O, Pplus.
  induction A. auto.  
Qed.

Lemma omega2: forall x,  1 * x = x.
Proof. intros. omega. Qed.

Lemma omega3': forall x, x + 0 = x.
Proof. intros. omega. Qed.
    
Lemma omega3: forall x y, (x + 0, y + 0)= (x, y).
Proof. intros. do 2 rewrite omega3'. reflexivity. Qed.

Lemma right_O: forall A, Pplus A O = A.
Proof.
  intros. unfold O. induction A. simpl. apply omega3.
Qed.

Lemma omega4: forall x, x * 0 = 0.
Proof. intros. omega. Qed.
  
Lemma lmult_O: forall n, Pmults n O = O.
Proof.
  intros. unfold O, Pmults. rewrite omega4; auto.
Qed.

Lemma Unit_right: forall A, Pmults 1 A = A.
Proof.
  intros. induction A.
  unfold Pmults. do 2 rewrite omega2. reflexivity.
Qed.

Axiom Unit_right': forall A, A = Pmults 1 A.

Axiom Pplus_1: forall A B, Pplus A B = O <-> A = Pmults (-1) B.
Axiom Pmults_1: forall n m A, Pmults (n) (Pmults m A) = Pmults (n * m) A.

Lemma Alge: forall x: Z, (-1) * (-1 *x) = x.
Proof. intros. omega. Qed.

Lemma collinO1: forall A B,
  (exists (l : Z), A = Pmults l B) -> collin A B O. 
Proof.
  intros. unfold collin. destruct H.  
  exists 1. exists (-1 * x). exists (1-x).
  intros. rewrite lmult_O with (n := (1-x)). rewrite Unit_right.
  apply Pplus_1. rewrite Pmults_1. rewrite Alge.
  auto.
Qed.

Definition Xcollin (A B C D F : Point) :=
  forall u v r s, u + v = r + s ->
         Pplus (Pmults u A) (Pmults v B) = Pplus (Pmults r C) (Pmults s D) ->
         Pmults (r + s) F = Pplus (Pmults r C) (Pmults s D).
                              

    
(** the definition of midpoint *)

Definition Midpoint (C A B : Point) :=
  Pmults 2 C = Pplus A B. 


