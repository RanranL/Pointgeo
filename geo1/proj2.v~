Lemma moveterm_1: forall A B C,
    A + B = C -> A = C - B.
Proof.
  intros. subst.
  unfold Pplus. unfold Pminus. induction A. induction B.
  assert (HX: forall r1 r2: R, (r1 + r2 - r2 = r1)%R).
  { intros. lra. } do 2 rewrite HX; reflexivity. 
Qed.

Lemma moveterm_2: forall A B C,
    A + B = C -> B = C - A.
Proof.
  intros. subst. unfold Pplus. unfold Pminus. induction A, B.
  assert (HX: forall r1 r2: R, (r1 + r2 - r1 = r2)%R).
  { intros. lra. } do 2 rewrite HX; reflexivity.
Qed.


Ltac Moveas A:=
  idtac "Move";
  match goal with
  | H: A + ?B = _ |- _ => apply moveterm_1 in H;subst
  | H: ?B + A = _ |- _ => apply moveterm_2 in H;subst
  end.

Lemma l1: forall A B C, A + (B - C) = A + B - C.
Proof.
  intros. unfold Pplus. unfold Pminus.
  induction A. induction B. induction C.
  assert ((n1 + (n0 - n4))%R = (n1 + n0 - n4)%R). lra. rewrite H.
  assert ((n2 + (n3 - n5))%R = (n2 + n3 - n5)%R). lra. rewrite H0.
  reflexivity.
Qed.

Lemma l2: forall A B C, A - (B + C) = A - B - C.
Proof.
  intros. unfold Pplus, Pminus. induction A, B, C.
  assert ((n1 - (n0 + n4))%R = (n1 - n0 - n4)%R). lra. 
  assert ((n2 - (n3 + n5))%R = (n2 - n3 - n5)%R). lra.
  rewrite H, H0. reflexivity.
Qed.


Lemma l3: forall A B C, A = C -> A - B = C - B.
Proof. intros. subst. reflexivity. Qed. 
  
 
Theorem p23_exam4: forall A B C D M N P Q,
    Parall A B C D ->
    Midpoint A M P ->
    Midpoint D M N ->
    Midpoint C Q N ->
    Midpoint B P Q.
Proof. 
  intros. unfold Parall, Midpoint in *. 
  symmetry in H.
  Moveas B. Moveas P. Moveas Q.
  rewrite Pmult_minus_distr_l.
  rewrite Pmult_plus_distr_l. rewrite <- H1.
  rewrite l1.
  rewrite l2.
  apply l3 with (B := N).
  rewrite Pplus_comm.
  rewrite l1.
  apply l3. rewrite Pplus_comm. reflexivity.
Qed.





                                         
