Lemma Pdistrib: forall A B C : Point,
   (((A - B) · C)%Point = (A · C)- (B · C))%R.
Proof.
  intros. unfold Pminus. unfold Pquantityprod.
  induction A. induction B. induction C. lra.
Qed.
       
Lemma Pcomm: forall A B,
    A · B = B · A.
Proof. unfold Pquantityprod. induction A. induction B. lra. Qed.   

Lemma Pdistrib_l: forall A B C : Point,
     ((A · C)- (B · C)=((A - B) · C)%Point)%R.
Proof.
  (*intros. unfold Pminus. unfold Pquantityprod. induction A. induction C. induction B. lra. Qed.*)
  intros. rewrite Pdistrib; auto.
Qed.

Lemma Rmove: forall a b : R,
    (a - b = 0 <-> a = b)%R.
Proof.
  intros. split; lra.
Qed.

Theorem tri_3_heights': forall A B C H,
    H = O ->
    Perpendicular B C A H ->
    Perpendicular B H A C ->
    Perpendicular C H A B.
Proof.
  intros.  Oelim. rewrite Pdistrib in *. rewrite Pcomm in H2.
  rewrite Pdistrib in H2. rewrite Pcomm in H1. rewrite Rmove in *. rewrite Pcomm. rewrite Pdistrib.
  rewrite Rmove. rewrite H1 in H2. rewrite Pcomm. rewrite H2.  rewrite Pcomm. auto.
Qed.

