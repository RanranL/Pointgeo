(** The following definition is to definite the property of three points collinear, and "col1" is the example for it. *)
Locate "_ + _".


Definition collin (A B P : Point) :=
  exists (u v t : R), (u + v)%R = t ->
                       (u * A) + (v * B) = t * P.

